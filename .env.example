# API Keys (DO NOT COMMIT - use environment variables on server)
# Copy this to .env on server and fill in your keys

# OpenAI
OPENAI_API_KEY=your_openai_key_here

# Gemini
GEMINI_API_KEY=your_gemini_key_here

# Ollama (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Bot config
BOT_HOST=0.0.0.0
BOT_PORT=8080
