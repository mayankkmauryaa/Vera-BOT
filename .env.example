# Vera Bot - Environment Variables (DO NOT COMMIT - use environment variables on server)
# Copy this to .env and fill in your keys
# Version: 1.2.0 (100/100 ready)

# Groq (primary LLM - fast, free, cloud)
# Get free key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (fallback - local, optional)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Bot config
BOT_HOST=0.0.0.0
BOT_PORT=8080

# Optional: OpenAI, Anthropic, Gemini (if using different LLM)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# GEMINI_API_KEY=your_gemini_key_here
